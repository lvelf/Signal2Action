actor:
  channels:
    - type: http
      url: http://localhost:8000/veris/requirement-agent
      method: POST
      request:
        message_field: message
      response:
        type: json
        message_field: response
  config:
    MAX_TURNS: "1"

agent:
  entry_point: uvicorn reqANA.api:app --host 0.0.0.0 --port 8000
  port: 8000

