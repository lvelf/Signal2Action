# Choose the model provider for requirement document generation: openai or baseten.
MODEL_PROVIDER=baseten

# Baseten Model APIs. Baseten is OpenAI-compatible for chat completions.
BASETEN_API_KEY=
BASETEN_BASE_URL=https://inference.baseten.co/v1
BASETEN_MODEL=deepseek-ai/DeepSeek-V3.1

# OpenAI fallback. Required only if MODEL_PROVIDER=openai or if you use /requirements/from-voice.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional. Used when you call VoiceRun's outbound session API yourself.
VOICERUN_API_KEY=
VOICERUN_AGENT_ID=
VOICERUN_ENVIRONMENT=development

# Optional. Used by Veris CLI login; do not commit real keys.
VERIS_API_KEY=

# Optional. VoiceRun injects transcribed speech into TextEvent for deployed agents.
# Keep VoiceRun credentials in the VoiceRun dashboard/environment rather than here
# unless you add direct VoiceRun REST calls later.
